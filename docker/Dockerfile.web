# ─── ERMAS Web (Next.js) ───────────────────────────────────────────────────────
FROM node:20-alpine AS builder

WORKDIR /app

# Install workspace dependencies first (cached while lockfile is unchanged).
COPY package.json package-lock.json ./
COPY apps/api/package.json ./apps/api/package.json
COPY apps/web/package.json ./apps/web/package.json
COPY packages ./packages
RUN npm ci

# Source
COPY tsconfig.json ./
COPY apps/web ./apps/web

# The browser calls the API directly, so this URL is baked in at build time.
# Set it to the address the BROWSER will use, e.g. http://<ubuntu-ip>:3001/api/v1
ARG NEXT_PUBLIC_API_URL=http://localhost:3001/api/v1
ENV NEXT_PUBLIC_API_URL=$NEXT_PUBLIC_API_URL

RUN npm run build -w @ermas/web

# ─── Runtime (standalone output — no node_modules needed) ─────────────────────
FROM node:20-alpine

WORKDIR /app
ENV NODE_ENV=production
ENV PORT=3000
ENV HOSTNAME=0.0.0.0

# next.config.js `output: 'standalone'` emits a self-contained server.
COPY --from=builder /app/apps/web/.next/standalone ./
COPY --from=builder /app/apps/web/.next/static ./apps/web/.next/static
COPY --from=builder /app/apps/web/public ./apps/web/public

EXPOSE 3000

CMD ["node", "apps/web/server.js"]
