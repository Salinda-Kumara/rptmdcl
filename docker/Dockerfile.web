# syntax=docker/dockerfile:1
# ─── ERMAS Web (Next.js) ───────────────────────────────────────────────────────
FROM node:20-alpine AS builder

WORKDIR /app

# Install workspace dependencies first (cached while lockfile is unchanged).
COPY package.json package-lock.json ./
COPY apps/api/package.json ./apps/api/package.json
COPY apps/web/package.json ./apps/web/package.json
COPY packages ./packages
# Cache mount persists downloaded packages across build attempts so a flaky
# registry connection makes forward progress instead of restarting each time.
# --maxsockets limits parallel connections that otherwise saturate a weak link.
RUN --mount=type=cache,target=/root/.npm \
    npm ci --fetch-timeout=600000 --fetch-retries=5 --fetch-retry-maxtimeout=120000 --maxsockets=3

# Source
COPY tsconfig.json ./
COPY apps/web ./apps/web

# The browser calls the API directly, so this URL is baked in at build time.
# Set it to the address the BROWSER will use, e.g. http://<ubuntu-ip>:3001/api/v1
ARG NEXT_PUBLIC_API_URL=http://localhost:3001/api/v1
ENV NEXT_PUBLIC_API_URL=$NEXT_PUBLIC_API_URL

RUN npm run build -w @ermas/web

# ─── Runtime (standalone output — no node_modules needed) ─────────────────────
FROM node:20-alpine

WORKDIR /app
ENV NODE_ENV=production
ENV PORT=3000
ENV HOSTNAME=0.0.0.0

# next.config.js `output: 'standalone'` emits a self-contained server.
COPY --from=builder /app/apps/web/.next/standalone ./
COPY --from=builder /app/apps/web/.next/static ./apps/web/.next/static
COPY --from=builder /app/apps/web/public ./apps/web/public

EXPOSE 3000

CMD ["node", "apps/web/server.js"]
