// ERMAS Prisma Schema

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ==================== Core User Management ====================

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String?  // null for students who use batch/NIC
  isAdmin   Boolean  @default(false) // Master Admin — full access bypass
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deletedAt DateTime?

  // Relations
  staffUser   StaffUser?
  student     Student?
  permissions UserPermission[]
  auditLogs   AuditLog[]
  remarks     Remark[]

  @@index([email])
  @@index([deletedAt])
}

// Per-user, per-feature access level. Absence of a row = no access (None).
enum AccessLevel {
  VIEW // read-only
  FULL // read + write
}

model UserPermission {
  userId    String
  resource  String      // feature key, e.g. "applications", "payments"
  level     AccessLevel
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([userId, resource])
  @@index([userId])
}

// ==================== Student Management ====================

model Student {
  id                String   @id @default(uuid())
  batchNumber       String   // e.g., AA22-105
  nic               String   // National ID Card
  fullName          String
  nameWithInitials  String?
  title             String?  // Mr. / Ms. (from import)
  gender            String?  // Male / Female (from import)
  permanentAddress  String?
  postalAddress     String?
  telephone         String?
  mobile            String?
  email             String?
  registrationNumber String  @unique
  intake            String
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  deletedAt         DateTime?

  // Relations
  user          User?   @relation(fields: [userId], references: [id])
  userId        String? @unique
  batch         Batch?  @relation(fields: [batchNumber, intake], references: [batchNumber, intake])
  applications  Application[]
  notifications Notification[]

  @@unique([batchNumber, nic, intake])
  @@index([email])
  @@index([registrationNumber])
  @@index([deletedAt])
}

model StaffUser {
  id        String   @id @default(uuid())
  name      String
  position  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId String @unique

  @@index([userId])
}

// ==================== Programme & Subject Management ====================

model Programme {
  id          String   @id @default(uuid())
  code        String   @unique
  name        String
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  deletedAt   DateTime?

  batches  Batch[]
  subjects Subject[]

  @@index([code])
  @@index([deletedAt])
}

model Batch {
  batchNumber String
  programmeId String
  intake      String    // e.g., "2022-01"
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  deletedAt   DateTime?

  programme Programme @relation(fields: [programmeId], references: [id])
  students  Student[]

  @@id([batchNumber, intake])
  @@unique([programmeId, batchNumber, intake])
  @@index([programmeId])
  @@index([deletedAt])
}

model Subject {
  id          String   @id @default(uuid())
  code        String
  name        String
  category    String
  programmeId String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  deletedAt   DateTime?

  programme           Programme @relation(fields: [programmeId], references: [id])
  applicationSubjects ApplicationSubject[]

  @@unique([code, programmeId])
  @@index([programmeId])
  @@index([deletedAt])
}

// ==================== Application Management ====================

model Application {
  id                String   @id @default(uuid())
  type              String   // MEDICAL, REPEAT
  status            String   @default("DRAFT") // DRAFT, SUBMITTED, PAYMENT_PENDING, etc.
  studentId         String
  totalFee          Int
  paymentReferenceId String?
  // Snapshot of the applicant's personal details as entered on THIS application
  // form. Corrections here do not modify the Student master record.
  applicantDetails  Json?
  serialNumber      String?   @unique // e.g. 20260627-01 — assigned on submission
  submittedAt       DateTime?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  deletedAt         DateTime?

  // Relations
  student            Student @relation(fields: [studentId], references: [id])
  applicationSubjects ApplicationSubject[]
  payment            Payment?
  documents          Document[]
  approvals          Approval[]
  remarks            Remark[]

  @@index([studentId])
  @@index([status])
  @@index([type])
  @@index([deletedAt])
}

model ApplicationSubject {
  id                  String    @id @default(uuid())
  applicationId       String
  subjectId           String
  caMarks             Int?      // CA marks (mandatory per form)
  category            String    // MEDICAL, REPEAT, 1ST_ATTEMPT (1ST_ATTEMPT for AA only)
  // Per-subject review outcome. ACTIVE by default; an Exam Division officer may
  // DECLINE a single wrong subject while forwarding the rest of the application.
  // Declined subjects are excluded from admissions (the paid total is unchanged).
  status              String    @default("ACTIVE") // ACTIVE, DECLINED
  declineReason       String?
  declinedAt          DateTime?
  declinedBy          String?   // email/id of the staff who declined it
  upcomingExamIntake  String?   // Upcoming exam intake e.g. "2024-06" (DD MM YYYY on form)
  upcomingExamDate    DateTime? // Auto-filled from ExaminationSchedule
  // Previous exam details (Section 6 of form) — 1st attempt.
  previousExamDate    DateTime?
  previousExamIntake  String?
  gradeEarned         String?   // For repeat: grade earned in previous attempt
  // Previous exam details — 2nd attempt (optional; a subject may have been sat twice).
  secondAttemptDate   DateTime?
  secondAttemptIntake String?
  secondAttemptGrade  String?
  // Medical-category only: the serial number on the medical board's approval,
  // recorded alongside the uploaded certificate.
  medicalApprovalSerial String?
  // Admission-card print tracking (per subject).
  admissionPrinted    Boolean   @default(false)
  admissionPrintedAt  DateTime?
  admissionPrintedBy  String?   // email/id of the staff who marked it printed
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  application Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  subject     Subject     @relation(fields: [subjectId], references: [id])
  documents   Document[]

  @@index([applicationId])
  @@index([subjectId])
}

// ==================== Payment Management ====================

model Payment {
  id                String   @id @default(uuid())
  applicationId     String   @unique
  amount            Int
  referenceNumber   String   // not unique — the same reference may be reused
  slipFile          String?  // MinIO path
  verificationStatus String  @default("PENDING") // PENDING, VERIFIED, REJECTED
  verifiedBy        String?
  verifiedAt        DateTime?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  deletedAt         DateTime?

  application Application @relation(fields: [applicationId], references: [id])

  @@index([applicationId])
  @@index([referenceNumber])
  @@index([verificationStatus])
  @@index([deletedAt])
}

// ==================== Document Management ====================

model Document {
  id              String   @id @default(uuid())
  applicationId   String
  // When set, this document belongs to a specific subject (e.g. a medical
  // certificate required for a Medical-category subject). Null for
  // application-level documents like the payment slip.
  applicationSubjectId String?
  documentType    String   // MEDICAL_CERTIFICATE, PAYMENT_SLIP
  fileName        String
  fileSize        Int
  mimeType        String
  minioPath       String   // Full path in MinIO
  uploadedBy      String
  uploadedAt      DateTime @default(now())
  deletedAt       DateTime?

  application        Application        @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  applicationSubject ApplicationSubject? @relation(fields: [applicationSubjectId], references: [id], onDelete: Cascade)

  @@index([applicationId])
  @@index([applicationSubjectId])
  @@index([documentType])
  @@index([deletedAt])
}

// ==================== Approval Workflow ====================

model Approval {
  id            String   @id @default(uuid())
  applicationId String
  stage         Int      // 1: Finance, 2: Verification, 3: Exam Manager, etc.
  status        String   @default("PENDING") // PENDING, APPROVED, REJECTED, RETURNED
  approvedBy    String?
  approvedAt    DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  application Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)

  @@unique([applicationId, stage])
  @@index([status])
}

model Remark {
  id            String   @id @default(uuid())
  applicationId String
  userId        String
  content       String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  application Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  user        User        @relation(fields: [userId], references: [id])

  @@index([applicationId])
  @@index([userId])
}

// ==================== Audit & Notifications ====================

model AuditLog {
  id            String   @id @default(uuid())
  userId        String
  action        String
  entity        String
  entityId      String
  details       String?  // JSON stringified
  ipAddress     String?
  userAgent     String?
  createdAt     DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([entityId])
  @@index([createdAt])
}

model Notification {
  id        String   @id @default(uuid())
  studentId String
  title     String
  message   String
  read      Boolean  @default(false)
  readAt    DateTime?
  createdAt DateTime @default(now())

  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@index([studentId])
  @@index([read])
}

// ==================== Examination Schedule ====================

model ExaminationSchedule {
  id           String   @id @default(uuid())
  name         String
  startDate    DateTime
  endDate      DateTime
  programmeId  String?  // Optional — a schedule can hold exams across programmes
  description  String?
  published    Boolean  @default(false) // when true, viewable on the public link
  publicToken  String?  @unique          // stable slug for the public view-only page
  publishedAt  DateTime?
  applyEnabled Boolean  @default(false) // when true, student applications auto-fill from this schedule
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  deletedAt    DateTime?

  exams        ScheduledExam[]

  @@index([startDate])
  @@index([deletedAt])
}

// Directory of exam-duty staff, organised by role/category. People are added
// here once, then picked when scheduling each exam.
model ExamStaff {
  id        String   @id @default(uuid())
  name      String
  role      String   // EXAMINER, SUPERVISOR, INVIGILATOR, SUPPORTING, OTHER
  phone     String?
  email     String?
  note      String?
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deletedAt DateTime?

  @@index([role])
  @@index([deletedAt])
}

// Directory of exam venues/halls used when allocating exams.
model ExamLocation {
  id        String   @id @default(uuid())
  name      String
  capacity  Int?
  note      String?
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deletedAt DateTime?

  @@index([deletedAt])
}

// One exam paper / timetable row within an ExaminationSchedule. Mirrors the
// columns of the printed ESE schedule. Staff fields hold ExamStaff ids (a slot
// can have several people, e.g. multiple invigilators).
model ScheduledExam {
  id               String    @id @default(uuid())
  scheduleId       String
  orderIndex       Int       @default(0)
  serialCode       String?   // e.g. 2026/165
  startAtLabel     String?   // "Exams to be start at", e.g. "28. June"
  examDate         DateTime? // ESE Date
  weekday          String?   // ESE Date Weekday
  revisedDate      DateTime?
  intake           String?   // e.g. "3B WE/MOHE WE"
  courseCode       String?   // e.g. BMBA1212
  courseName       String?
  expectedCount    Int?
  session1         String?   // time-slot label, e.g. "9.00-11.30am"
  session2         String?
  session3         String?
  location         String?
  chiefExaminerIds String[]  @default([])
  supervisorIds    String[]  @default([])
  invigilatorIds   String[]  @default([])
  supportingIds    String[]  @default([])
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  schedule ExaminationSchedule @relation(fields: [scheduleId], references: [id], onDelete: Cascade)

  @@index([scheduleId])
  @@index([examDate])
}
