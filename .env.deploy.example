# Copy to .env next to docker-compose.deploy.yml and edit.

# The address users' BROWSERS will reach the server on.
# LAN deploy: the Ubuntu machine's IP (e.g. 192.168.1.50). Same-machine: localhost.
HOST_ADDR=localhost

# Postgres credentials (containers only; not exposed outside the compose network
# unless you add a ports mapping).
POSTGRES_USER=ermas
POSTGRES_PASSWORD=change-me-strong

# Generate strong values, e.g.:  openssl rand -base64 48
JWT_SECRET=change-me-long-random-string
JWT_REFRESH_SECRET=change-me-another-long-random-string

# ── SMTP (staff "Forgot password" OTP emails) ──
# Example: Brevo (formerly Sendinblue) SMTP relay — https://app.brevo.com -> SMTP & API.
SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=change-me-smtp-login
SMTP_PASS=change-me-smtp-key
SMTP_FROM="ERMAS <noreply@yourdomain.com>"

# ── Public access via domain + Cloudflare Tunnel (optional) ──
# Only needed when running with docker-compose.public.yml. See docs/DEPLOYMENT.md.
# The domain users will visit (must be a zone on your Cloudflare account).
PUBLIC_DOMAIN=ermas.example.com
# Tunnel token from Cloudflare Zero Trust -> Networks -> Tunnels -> your tunnel.
CF_TUNNEL_TOKEN=change-me-cloudflare-tunnel-token
